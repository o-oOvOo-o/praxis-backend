{
  "schema_version": 1,
  "cache_subdir": "toolchains",
  "archive_subdirs": [
    "toolchains/vendor_archives",
    "vendor_archives",
    "archives"
  ],
  "tools": [
    {
      "id": "java-jdk",
      "label": "Java JDK for Ghidra headless",
      "category": "runtime",
      "required": true,
      "env_vars": [
        "JAVA_HOME"
      ],
      "path_candidates": [
        "C:\\Program Files\\Microsoft\\jdk-21.0.10.7-hotspot\\bin\\java.exe",
        "C:\\Program Files\\Eclipse Adoptium\\jdk-*\\bin\\java.exe",
        "C:\\Program Files\\Java\\jdk*\\bin\\java.exe"
      ],
      "which": [
        "java"
      ],
      "version_args": [
        "-version"
      ],
      "redistribution": "external_or_redistributable_runtime",
      "license_policy": "external_install_or_redistributable_runtime",
      "notes": "Required by Ghidra analyzeHeadless."
    },
    {
      "id": "ghidra",
      "label": "Ghidra headless decompiler",
      "category": "native_decompiler",
      "required": true,
      "env_vars": [
        "GHIDRA_INSTALL_DIR",
        "GHIDRA_HOME"
      ],
      "path_candidates": [
        "F:\\tools\\ghidra_12.0.4_PUBLIC\\support\\analyzeHeadless.bat",
        "D:\\ghost1.0\\_external\\ghidra\\support\\analyzeHeadless.bat",
        "D:\\ghost1.0\\_c3d_devflywheeltool\\toolchains\\ghidra\\support\\analyzeHeadless.bat",
        "C:\\ghidra*\\support\\analyzeHeadless.bat"
      ],
      "cache_candidates": [
        "ghidra/support/analyzeHeadless.bat"
      ],
      "which": [
        "analyzeHeadless"
      ],
      "archive_names": [
        "ghidra*.zip"
      ],
      "redistribution": "cache_or_external",
      "license_policy": "oss_redistributable_check_release_terms",
      "notes": "Used by tools/gaea/run_ghidra_export.ps1 and native PE reverse evidence."
    },
    {
      "id": "ghidra-export-script",
      "label": "C3D Ghidra ExportFunctionArtifacts.java",
      "category": "repo_script",
      "required": true,
      "path_candidates": [
        "D:\\ghost1.0\\tools\\gaea\\ghidra\\ExportFunctionArtifacts.java"
      ],
      "redistribution": "repo",
      "license_policy": "project_owned",
      "notes": "Exports meta, decompiled C, pcode, and asm for native targets."
    },
    {
